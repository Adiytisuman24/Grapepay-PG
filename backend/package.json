{
  "name": "grapepay-backend",
  "version": "1.0.0",
  "private": true,
  "description": "GrapePay microservices backend",
  "workspaces": [
    "services/*",
    "shared"
  ],
  "scripts": {
    "install": "lerna bootstrap",
    "dev": "lerna run dev --parallel",
    "build": "lerna run build",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "lerna": "^7.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  }
}
